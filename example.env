# Configuração de Ambiente AIOS - Lote 2
# Copie este arquivo para .env e preencha com suas credenciais reais.

# OpenAI: Necessária para o motor de decisão (LLM)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=coloque_sua_chave_openai_aqui

# E2B: Necessária para a sandbox isolada
# Obtenha em: https://e2b.dev/docs/getting-started/api-key
E2B_API_KEY=coloque_sua_chave_e2b_aqui
